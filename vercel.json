{
  "installCommand": "npm install",
  "buildCommand": "tsc & P1=$!; tsx src/db/migrate.ts & P2=$!; wait $P1; R1=$?; wait $P2; R2=$?; [ $R1 -eq 0 ] && [ $R2 -eq 0 ]",
  "framework": null,
  "regions": [
    "fra1"
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 800
    }
  },
  "rewrites": [
    {
      "source": "/slack/events",
      "destination": "/api/index"
    },
    {
      "source": "/health",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/consolidate",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/heartbeat",
      "schedule": "*/30 * * * *"
    }
  ]
}
