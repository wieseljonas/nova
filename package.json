{
  "name": "aura",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "vercel-build": "tsc && tsx src/db/migrate.ts",
    "postinstall": "rm -rf node_modules/e2b/node_modules/chalk 2>/dev/null; true",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/gateway": "^3.0.46",
    "@elevenlabs/elevenlabs-js": "^2.36.0",
    "@google-cloud/bigquery": "^8.1.1",
    "@googleapis/calendar": "^14.2.0",
    "@googleapis/drive": "^20.1.0",
    "@googleapis/gmail": "^16.1.1",
    "@hono/node-server": "^1.19.9",
    "@neondatabase/serverless": "^1.0.0",
    "@slack/web-api": "^7.14.0",
    "@tavily/core": "^0.7.1",
    "@vercel/functions": "^3.4.2",
    "ai": "^6.0.86",
    "chalk": "4.1.2",
    "cron-parser": "^5.5.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.44.0",
    "e2b": "^2.12.1",
    "google-auth-library": "^10.5.0",
    "hono": "^4.11.9",
    "playwright-core": "^1.58.2",
    "turndown": "^7.2.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/turndown": "^5.0.6",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
