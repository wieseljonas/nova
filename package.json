{
  "name": "nova-monorepo",
  "private": true,
  "scripts": {
    "db:generate": "pnpm --filter @aura/db db:generate",
    "db:migrate": "pnpm --filter @aura/db db:migrate",
    "db:push": "pnpm --filter @aura/db db:push",
    "db:studio": "pnpm --filter @aura/db db:studio"
  },
  "devDependencies": {
    "e2b": "^2.12.1"
  },
  "pnpm": {
    "overrides": {
      "e2b>chalk": "4.1.2"
    }
  }
}